<?xml version="1.0" ?>
<robot name="featherbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find featherbot_description)/urdf/materials.xacro" />
<xacro:include filename="$(find featherbot_ros2_control)/ros2_control/featherbot.ros2_control.xacro" />

<xacro:featherbot_ros2_control/>

<xacro:if value="$(arg use_sim)">
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find featherbot_ros2_control)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>
</xacro:if>
